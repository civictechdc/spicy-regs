{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: spicy-regs CLI",
            "type": "debugpy",
            "request": "launch",
            "module": "spicy_regs.cli",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: run-pipeline (etl)",
            "type": "debugpy",
            "request": "launch",
            "module": "spicy_regs.pipelines.regulations",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: spicy-regs MCP server (stdio)",
            "type": "debugpy",
            "request": "launch",
            "module": "spicy_regs.mcp_server",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: pytest (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
